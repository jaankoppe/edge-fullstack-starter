{
  "name": "edge-fullstack-starter",
  "description": "A full-stack app on Cloudflare's edge — user accounts, a database, and file uploads — wired the cheap way (KV sessions, D1, R2). One-click deploy, zero external services.",
  "private": true,
  "type": "module",
  "cloudflare": {
    "label": "Edge Full-Stack Starter",
    "products": ["Workers", "D1", "R2"],
    "categories": ["starter"],
    "docs_url": "https://github.com/flarelink-dev/cloudflare-edge-fullstack-starter#readme",
    "publish": false
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
